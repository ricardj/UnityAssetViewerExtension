{
  "name": "vscode-extension",
  "publisher": "unity-asset-viewer",
  "displayName": "Unity Asset Viewer",
  "description": "Visual Studio Code extension to view Unity Prefabs",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCommand:unityAssetViewer.showPreview"
  ],
  "contributes": {
    "commands": [
      {
        "command": "unityAssetViewer.showPreview",
        "title": "Unity Asset Viewer: Show Preview",
        "category": "Unity"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == .prefab",
          "command": "unityAssetViewer.showPreview",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .prefab",
          "command": "unityAssetViewer.showPreview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "vite build && vite build -c vite.webview.config.ts",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@unity-asset-viewer/core-parser": "^1.0.0",
    "@unity-asset-viewer/core-renderer": "^1.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
